---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const proyectos = await getCollection('proyectos');
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="Proyectos - USACH Space Program">
  <div class="projects-slider">
    {proyectos.map((proyecto) => {
      const bgStyle = proyecto.data.backgroundImage 
        ? `url(${proyecto.data.backgroundImage.src})` 
        : 'none';
      return (
        <div class="project-card">
          <div class="project-image" style={{ backgroundImage: bgStyle, backgroundColor: '#222' }}></div>
          <div class="project-info">
            <div>
              <span class="eje-tag">{proyecto.data.specs?.rol || 'EJE DE DESARROLLO'}</span>
              <h2>{proyecto.data.title}</h2>
              <p>{proyecto.data.description}</p>
            </div>
            <a href={`${baseUrl}proyectos/${proyecto.slug}/`} class="btn-details">Más detalles</a>
          </div>
        </div>
      );
    })}
  </div>

  <div class="scroll-indicator">USA EL SCROLL HORIZONTAL (SHIFT + RUEDA) O DESLIZA PARA NAVEGAR</div>
</Layout>

<style>
  /* En escritorio ocultamos el scroll vertical para forzar la experiencia de juego */
  @media (min-width: 1025px) {
      :global(body), :global(html) {
          overflow-y: hidden;
      }
  }

  /* === CONFIGURACIÓN DEL SLIDER HORIZONTAL (ESCRITORIO) === */
  .projects-slider {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      height: 100vh;
      align-items: center;
      padding: 0 10vw;
      gap: 10vw;
      box-sizing: border-box;
      scrollbar-width: none; /* Oculta barra en Firefox */
      margin-top: 20px;
  }
  
  .projects-slider::-webkit-scrollbar {
      display: none; /* Oculta barra en Chrome/Edge/Safari */
  }

  .project-card {
      scroll-snap-align: center;
      flex: 0 0 80vw;
      height: 70vh;
      background-color: var(--card-bg);
      border-radius: 12px;
      border: 1px solid #333;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(0,0,0,0.8);
      margin-top: 50px;
  }

  .project-image {
      height: 50%;
      background-size: cover;
      background-position: center;
      position: relative;
  }

  .project-image::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; width: 100%; height: 50%;
      background: linear-gradient(to bottom, transparent, var(--card-bg));
  }

  .project-info {
      height: 50%;
      padding: 30px 50px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-sizing: border-box;
  }

  .project-info h2 {
      font-size: 2.5rem;
      margin: 5px 0 10px 0;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: var(--text-main);
  }

  .project-info .eje-tag {
      color: var(--nasa-blue-glow);
      font-weight: bold;
      letter-spacing: 1px;
      font-size: 0.85rem;
      display: inline-block;
      text-transform: uppercase;
  }

  .project-info p {
      font-size: 1.1rem;
      line-height: 1.6;
      color: var(--text-muted);
      margin: 0;
  }

  .btn-details {
      align-self: flex-start;
      background-color: var(--nasa-blue);
      color: #fff;
      text-decoration: none;
      padding: 12px 35px;
      font-size: 1rem;
      font-weight: bold;
      text-transform: uppercase;
      border-radius: 4px;
      letter-spacing: 1px;
      transition: background-color 0.3s ease;
  }

  .btn-details:hover { background-color: #082d6b; }

  .scroll-indicator {
      position: fixed;
      bottom: 25px;
      width: 100%;
      text-align: center;
      color: #555;
      letter-spacing: 2px;
      font-size: 0.85rem;
      pointer-events: none;
      z-index: 10;
  }

  /* --- AJUSTES PARA TABLETS --- */
  @media (max-width: 1024px) and (min-width: 769px) {
      .project-card { flex: 0 0 75vw; height: 65vh; }
      .project-info h2 { font-size: 2.2rem; }
  }

  /* --- AJUSTES PARA TELÉFONOS --- */
  @media (max-width: 768px) {
      :global(html), :global(body) {
          overflow-x: hidden;
          width: 100%;
          overflow-y: auto !important; /* Permitimos scroll vertical en móviles */
      }

      /* Reajuste completo del Slider en móvil */
      .projects-slider {
          height: auto;
          min-height: calc(100vh - 80px);
          padding: 100px 5vw 40px !important;
          gap: 40px;
          flex-direction: column;
          overflow-x: hidden;
      }

      .project-card {
          flex: 0 0 auto !important;
          width: 90vw !important;
          height: auto !important;
          margin-top: 0;
      }

      .project-image { height: 200px !important; }
      .project-info { height: auto !important; padding: 25px 20px !important; gap: 15px; }
      .project-info h2 { font-size: 1.8rem !important; }
      .project-info p { font-size: 0.95rem !important; }
      .btn-details { align-self: stretch !important; text-align: center; padding: 14px !important; }
      .scroll-indicator { display: none; }
  }
</style>
