---
import Layout from '../layouts/Layout.astro';
import logoImg from '../assets/logo.png';
import tierraImg from '../assets/Tierra.png';
import wa0030 from '../assets/gallery/IMG-20260607-WA0030.jpg';
import wa0039 from '../assets/gallery/IMG-20260607-WA0039.jpg';
import galleryImg1 from '../assets/gallery/IMG-20260605-WA0073.jpg';
import galleryImg2 from '../assets/gallery/IMG-20260607-WA0022.jpg';
import galleryImg3 from '../assets/gallery/IMG-20260611-WA0050.jpg';

const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith('/') ? rawBaseUrl : `${rawBaseUrl}/`;
---

<Layout title="USACH Space Program - Innovación Aeroespacial Estudiantil">
  <section class="hero" style={{ backgroundImage: `url(${tierraImg.src})` }}>
    <div class="hero-content">
      <img src={logoImg.src} alt="Logo USP" />
      <h1>USACH Space Program</h1>
      <p>Impulsando la innovación aeroespacial estudiantil en Chile hacia el infinito.</p>
      <a href="#proyectos" class="btn-cta">Explorar Operaciones</a>
    </div>
  </section>

  <section class="quote-section">
    <div class="quote">
      "La ciencia no pertenece a un solo hombre ni a una sola época; pertenece a cualquiera que esté dispuesto a sacrificar su presente por el progreso del mañana"
    </div>
  </section>

  <section class="about-section">
    <div class="about-desc">
      <p>Usach Space Program es una iniciativa estudiantil autogestionada que nace con el objetivo de ser el primer acercamiento extracurricular de los estudiantes hacia el sector aeroespacial, proyectándose como un espacio interdisciplinario y una incubadora de ideas.</p>
    </div>
    <div class="mission-vision-container">
      <div class="card">
        <h3>Nuestra Misión</h3>
        <p>Consolidarnos como el principal núcleo de colaboración interdisciplinaria de la USACH, posicionando el talento de nuestra universidad dentro de la industria aeroespacial nacional e internacional.</p>
      </div>
      <div class="card">
        <h3>Nuestra Visión</h3>
        <p>Impulsar el desarrollo científico-tecnológico en el ámbito aeroespacial dentro de la comunidad universitaria mediante la ejecución autogestionada de proyectos tangibles.</p>
      </div>
    </div>
  </section>

  <section class="projects-section" id="proyectos">
    <h2>Un Ecosistema de Innovación</h2>
    <p class="projects-desc">Nuestra estructura operativa está diseñada para abarcar desde la alfabetización técnica de nuevos estudiantes hasta el prototipado de hardware aeroespacial avanzado de nuestra directiva técnica.</p>

    <!-- NIVEL 1: COMUNIDAD -->
    <div class="tier-title community">
      Iniciativas de Comunidad
      <span class="tier-badge badge-community">NIVEL 1: ONBOARDING</span>
    </div>
    <p class="tier-intro-text">Proyectos ágiles y accesibles diseñados para permeabilizar el conocimiento aeroespacial a estudiantes con o sin experiencia previa.</p>
    
    <div class="projects-grid">
      <div class="project-card community-card">
        <div class="project-content">
          <h4>CubeSat 1U (Educativo)</h4>
          <p>Misión de introducción a la aviónica y telemetría. Empaquetado de sensores y comunicación dentro del estándar de 10x10x10 cm.</p>
          <a href={`${baseUrl}proyectos/cansat/`} class="btn-project">Explorar Misión</a>
        </div>
      </div>
      <div class="project-card community-card">
        <div class="project-content">
          <h4>Mini-Rover Explorador</h4>
          <p>Diseño y construcción de vehículos a escala para sortear obstáculos. Introducción práctica a la robótica y el diseño 3D.</p>
          <a href={`${baseUrl}proyectos/rover/`} class="btn-project">Explorar Misión</a>
        </div>
      </div>
      <div class="project-card community-card">
        <div class="project-content">
          <h4>Cohetería de Sondeo (Agua)</h4>
          <p>Aplicación de las leyes de Newton, cálculo del centro de presión y gravedad mediante vehículos de introducción a presión.</p>
          <a href={`${baseUrl}proyectos/cohete/`} class="btn-project">Explorar Misión</a>
        </div>
      </div>
      <div class="project-card community-card">
        <div class="project-content">
          <h4>Simulación Egg Drop</h4>
          <p>Desafío de gestión de energía e impacto. Diseño de estructuras de sacrificio para proteger una carga útil durante una caída libre.</p>
          <a href={`${baseUrl}proyectos/eggdrop/`} class="btn-project">Explorar Misión</a>
        </div>
      </div>
      <div class="project-card community-card">
        <div class="project-content">
          <h4>Taller de Impresión 3D</h4>
          <p>Nivelación técnica en modelado CAD paramétrico y manufactura aditiva, herramientas vitales para la organización.</p>
          <a href={`${baseUrl}proyectos/impresion3d/`} class="btn-project">Explorar Taller</a>
        </div>
      </div>
    </div>

    <!-- NIVEL 2: FLAGSHIP / DESARROLLO AVANZADO -->
    <div class="tier-title flagship" style="margin-top: 80px;">
      Proyectos Insignia (Desarrollo Avanzado)
      <span class="tier-badge badge-flagship">NIVEL 2: ESTANDARTE USP</span>
    </div>
    <p class="tier-intro-text">Plataformas de experimentación y prototipado complejo desarrolladas por los miembros experimentados y la dirección técnica del equipo.</p>
    
    <div class="projects-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
      <div class="project-card flagship-card">
        <div class="project-image" style={{ backgroundImage: `url(${wa0030.src})` }}></div>
        <div class="project-content">
          <h4>Rover Plataforma "Mascota"</h4>
          <p>Vehículo de exploración de escala mayor y complejidad avanzada. Integra cinemática de suspensión compleja, telemetría de largo alcance, diseño mecatrónico robusto y visión computacional.</p>
          <a href={`${baseUrl}proyectos/rover_avanzado/`} class="btn-project">Desarrollo Interno</a>
        </div>
      </div>
      <div class="project-card flagship-card">
        <div class="project-image" style={{ backgroundImage: `url(${wa0039.src})` }}></div>
        <div class="project-content">
          <h4>CubeSat 3U Avanzado</h4>
          <p>Desarrollo del hardware estandarte del programa. Un satélite de 3 unidades (10x10x30 cm) orientado a la prueba rigurosa de control de altitud, paneles de potencia y enlaces con estación terrena.</p>
          <a href={`${baseUrl}proyectos/cubesat_avanzado/`} class="btn-project">Desarrollo Interno</a>
        </div>
      </div>
    </div>
  </section>

  <section class="ejes-section">
    <h2>Pilares de Desarrollo</h2>
    <div class="ejes-summary">
      <div class="ejes-icon-card"><span class="eje-badge">01</span><h4>Exploración Planetaria</h4></div>
      <div class="ejes-icon-card"><span class="eje-badge">02</span><h4>Simulación y Operaciones</h4></div>
      <div class="ejes-icon-card"><span class="eje-badge">03</span><h4>Cohetería de Sondeo</h4></div>
      <div class="ejes-icon-card"><span class="eje-badge">04</span><h4>Sistemas y Energía</h4></div>
      <div class="ejes-icon-card"><span class="eje-badge">05</span><h4>Educación y Experiencia</h4></div>
    </div>
    <a href={`${baseUrl}ejes/`} class="btn-project" style="margin-top: 40px; border-color: var(--nasa-blue-glow); color: var(--nasa-blue-glow);">Ver Ejes Completos</a>
  </section>

  <section class="gallery-section">
    <h2>Registro de Operaciones</h2>
    <div class="carousel">
      <div class="carousel-item" style={{ backgroundImage: `url(${galleryImg1.src})` }}></div>
      <div class="carousel-item" style={{ backgroundImage: `url(${galleryImg2.src})` }}></div>
      <div class="carousel-item" style={{ backgroundImage: `url(${galleryImg3.src})` }}></div>
    </div>
  </section>
</Layout>

<style>
  /* === LOCAL HERO & LANDING SECTIONS === */
  .hero {
      height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
      background-repeat: no-repeat; background-position: center center; background-size: cover; background-color: var(--dark-bg); position: relative;
  }
  .hero::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.65); z-index: 1; }
  .hero::after {
      content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      background-image: radial-gradient(1.5px 1.5px at 20px 30px, #ffffff, rgba(0,0,0,0)), radial-gradient(1px 1px at 40px 70px, #e0e0e0, rgba(0,0,0,0)), radial-gradient(2px 2px at 50px 160px, #ffffff, rgba(0,0,0,0));
      background-repeat: repeat; background-size: 250px 250px; opacity: 0.25; z-index: 2;
  }
  .hero-content { z-index: 3; text-align: center; position: relative; }
  .hero img { width: 180px; margin-bottom: 20px; }
  .hero h1 { font-size: 4rem; margin: 0; letter-spacing: 4px; text-transform: uppercase; text-shadow: 0 0 15px rgba(255,255,255,0.3); color: var(--text-main); }
  .hero p { color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 10px auto 0 auto; }
  .btn-cta { display: inline-block; margin-top: 30px; padding: 12px 30px; background-color: var(--nasa-blue); color: var(--text-main); text-decoration: none; font-weight: 700; text-transform: uppercase; border-radius: 4px; letter-spacing: 1px; transition: background-color 0.3s ease; }
  .btn-cta:hover { background-color: var(--nasa-red); }

  .quote-section { padding: 100px 20px; text-align: center; background-color: var(--darker-bg); border-bottom: 1px solid #222; }
  .quote { font-size: 2.2rem; font-style: italic; font-weight: 300; max-width: 900px; margin: auto; color: #ddd; }

  .about-section { padding: 100px 10%; background-color: var(--dark-bg); }
  .about-desc { text-align: center; margin-bottom: 60px; font-size: 1.2rem; line-height: 1.8; max-width: 800px; margin: auto auto 60px auto; color: var(--text-muted); }
  .mission-vision-container { display: flex; gap: 40px; flex-wrap: wrap; }
  .card { flex: 1; min-width: 300px; background: var(--card-bg); padding: 40px; border-radius: 8px; border-top: 4px solid var(--nasa-blue); transition: transform 0.3s; }
  .card:hover { transform: translateY(-5px); box-shadow: 0 5px 15px rgba(11, 61, 145, 0.2); }
  .card h3 { font-size: 1.8rem; text-transform: uppercase; margin-top: 0; letter-spacing: 1.5px; color: var(--text-main); }
  .card p { line-height: 1.7; color: #ccc; }

  /* PROJECTS ECOSYSTEM */
  .projects-section { padding: 100px 10%; background-color: var(--darker-bg); border-top: 1px solid #222; }
  .projects-section h2 { text-align: center; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; font-size: 2.5rem; color: var(--text-main); }
  .projects-desc { text-align: center; color: var(--text-muted); max-width: 800px; margin: 0 auto 60px auto; font-size: 1.1rem; line-height: 1.6;}

  .tier-title {
      font-size: 1.8rem; text-transform: uppercase; letter-spacing: 2px;
      margin: 60px 0 15px 0; padding-bottom: 15px; border-bottom: 1px solid #333;
      color: var(--text-main); display: flex; align-items: center; justify-content: space-between;
  }
  .tier-title.community { border-color: var(--nasa-blue-glow); }
  .tier-title.flagship { border-color: var(--nasa-gold); }
  .tier-badge { font-size: 0.9rem; padding: 5px 15px; border-radius: 20px; font-weight: bold; letter-spacing: 1px; }
  .badge-community { background-color: rgba(26, 95, 255, 0.2); color: var(--nasa-blue-glow); }
  .badge-flagship { background-color: rgba(255, 183, 3, 0.2); color: var(--nasa-gold); }
  .tier-intro-text { color: var(--text-muted); margin-top: 0; margin-bottom: 30px; font-size: 1rem; }

  .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }
  .project-card { background-color: var(--card-bg); border-radius: 8px; overflow: hidden; border: 1px solid #222; transition: transform 0.3s, border-color 0.3s; display: flex; flex-direction: column;}
  .project-card.community-card:hover { transform: translateY(-5px); border-color: var(--nasa-blue-glow); }
  .project-card.flagship-card:hover { transform: translateY(-5px); border-color: var(--nasa-gold); }

  .project-image { width: 100%; height: 200px; background-size: cover; background-position: center; }
  .project-content { padding: 30px; flex-grow: 1; display: flex; flex-direction: column; }
  .project-content h4 { margin-top: 0; font-size: 1.3rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-main); }
  .project-content p { color: var(--text-muted); line-height: 1.6; flex-grow: 1; margin-bottom: 20px; }
  
  .btn-project { display: inline-block; padding: 10px 20px; background-color: transparent; border: 1px solid var(--text-main); color: var(--text-main); text-decoration: none; font-weight: 600; text-transform: uppercase; border-radius: 4px; font-size: 0.8rem; text-align: center; transition: all 0.3s; }
  .community-card .btn-project:hover { background-color: var(--nasa-blue-glow); border-color: var(--nasa-blue-glow); color: #fff; }
  .flagship-card .btn-project:hover { background-color: var(--nasa-gold); border-color: var(--nasa-gold); color: #000; }

  /* PILLARES SECTION */
  .ejes-section { padding: 100px 10%; background-color: var(--dark-bg); text-align: center; }
  .ejes-section h2 { text-transform: uppercase; letter-spacing: 2px; font-size: 2.5rem; margin-bottom: 40px; color: var(--text-main); }
  .ejes-summary { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; }
  .ejes-icon-card { background-color: var(--card-bg); padding: 30px; border-radius: 8px; border: 1px solid #222; flex: 1 1 200px; text-align: left; transition: border-color 0.3s; }
  .ejes-icon-card:hover { border-color: var(--nasa-blue-glow); }
  .ejes-icon-card .eje-badge { color: var(--nasa-blue-glow); font-size: 0.8rem; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; display: block; }
  .ejes-icon-card h4 { font-size: 1.1rem; text-transform: uppercase; margin: 0 0 10px 0; color: var(--text-main); }

  /* CAROUSEL */
  .gallery-section { padding: 100px 0; background-color: var(--darker-bg); text-align: center; border-top: 1px solid #222; }
  .gallery-section h2 { text-transform: uppercase; letter-spacing: 2px; margin-bottom: 60px; font-size: 2.5rem; color: var(--text-main); }
  .carousel { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 20px; padding: 0 10% 20px 10%; scrollbar-width: thin; scrollbar-color: var(--nasa-blue) #222; }
  .carousel::-webkit-scrollbar { height: 8px; }
  .carousel::-webkit-scrollbar-thumb { background-color: var(--nasa-blue); border-radius: 4px; }
  .carousel-item { min-width: 400px; height: 280px; background-color: #333; scroll-snap-align: center; border-radius: 8px; background-size: cover; background-position: center; transition: transform 0.3s; }
  .carousel-item:hover { transform: scale(1.03); }

  @media (max-width: 1024px) {
      .tier-title { flex-direction: column; align-items: flex-start; gap: 10px; }
      .carousel-item { min-width: 300px; height: 200px; }
      .projects-section, .ejes-section, .about-section { padding-left: 20px; padding-right: 20px; }
      .hero h1 { font-size: 2.6rem; }
  }
</style>
